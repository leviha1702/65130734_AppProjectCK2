<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:orientation="vertical"
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Tiêu đề -->
        <TextView
            android:text="Đánh giá tình trạng đầu gối"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#222"
            android:layout_marginBottom="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Mức độ đau -->
        <TextView
            android:text="Mức độ đau"
            android:textStyle="bold"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Spinner
            android:id="@+id/spinnerPain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="12dp"/>

        <!-- Triệu chứng -->
        <TextView
            android:text="Triệu chứng bạn gặp phải"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <CheckBox
            android:id="@+id/cbUnstable"
            android:text="Lỏng gối / cảm giác không vững"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <CheckBox
            android:id="@+id/cbRunPain"
            android:text="Đau khi chạy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <CheckBox
            android:id="@+id/cbStairs"
            android:text="Đau khi lên xuống cầu thang"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <CheckBox
            android:id="@+id/cbSwelling"
            android:text="Sưng đầu gối"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <CheckBox
            android:id="@+id/cbSound"
            android:text="Có tiếng kêu khi cử động"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <CheckBox
            android:id="@+id/cbWeak"
            android:text="Yếu chân / mất lực"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Nhập mô tả thêm -->
        <TextView
            android:text="Mô tả thêm (tuỳ chọn)"
            android:textStyle="bold"
            android:layout_marginTop="12dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <EditText
            android:id="@+id/edtDescription"
            android:hint="Ví dụ: đau khi đá bóng, khó duỗi thẳng..."
            android:minHeight="100dp"
            android:gravity="top"
            android:background="@android:drawable/editbox_background"
            android:padding="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- Button -->
        <Button
            android:id="@+id/btnAnalyze"
            android:text="Phân tích và Gợi ý"
            android:textColor="#FFF"
            android:backgroundTint="#3F51B5"
            android:layout_marginTop="20dp"
            android:layout_width="match_parent"
            android:layout_height="50dp"/>

    </LinearLayout>

</ScrollView>